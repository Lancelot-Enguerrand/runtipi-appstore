{
  "services": [
    {
      "name": "zigbee2mqtt",
      "image": "koenkk/zigbee2mqtt:1.42.0",
      "isMain": true,
      "internalPort": 8080,
      "expose": [
        8080
      ],
      "environment": {
        "TZ": "${TZ}"
      },
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/",
          "containerPath": "/app/data"
        }
      ],
      "devices": [
        "${Z2M_DEVICE}:/dev/ttyACM0"
      ]
    }
  ]
}
