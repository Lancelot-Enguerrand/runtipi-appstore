{
  "services": [
    {
      "name": "autobrr",
      "image": "ghcr.io/autobrr/autobrr:v1.56.1",
      "isMain": true,
      "internalPort": 7474,
      "user": "1000:1000",
      "environment": {
        "TZ": "${TZ}"
      },
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/autobrr",
          "containerPath": "/config"
        }
      ]
    }
  ]
}
