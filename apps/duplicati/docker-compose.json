{
  "services": [
    {
      "name": "duplicati",
      "image": "lscr.io/linuxserver/duplicati:2.0.8",
      "isMain": true,
      "internalPort": 8200,
      "environment": {
        "PUID": "1000",
        "PGID": "1000",
        "TZ": "${TZ}"
      },
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/duplicati-config",
          "containerPath": "/config"
        },
        {
          "hostPath": "${ROOT_FOLDER_HOST}",
          "containerPath": "/backups/runtipi-folder"
        },
        {
          "hostPath": "/home",
          "containerPath": "/source"
        }
      ]
    }
  ]
}
