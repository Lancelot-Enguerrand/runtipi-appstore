{
  "services": [
    {
      "name": "zerotier",
      "image": "zerotier/zerotier:1.14.1",
      "isMain": true,
      "networkMode": "host",
      "command": "${NETWORK_ID}",
      "devices": [
        "/dev/net/tun"
      ],
      "capAdd": [
        "NET_ADMIN",
        "SYS_ADMIN"
      ],
      "healthCheck": {
        "test": [
          "CMD",
          "true"
        ],
        "interval": "30s",
        "timeout": "30s",
        "retries": 3
      }
    }
  ]
}
