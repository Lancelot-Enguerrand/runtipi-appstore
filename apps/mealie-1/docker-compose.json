{
  "services": [
    {
      "name": "mealie-1",
      "image": "ghcr.io/mealie-recipes/mealie:v2.3.0",
      "isMain": true,
      "internalPort": 9000,
      "environment": {
        "ALLOW_SIGNUP": "${MEALIE_ALLOW_SIGNUP}",
        "PUID": 1000,
        "PGID": 1000,
        "TZ": "${TZ}",
        "MAX_WORKERS": 1,
        "WEB_CONCURRENCY": 1,
        "BASE_URL": "${APP_PROTOCOL:-http}://${APP_DOMAIN}"
      },
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/app/data"
        }
      ],
      "deploy": {
        "resources": {
          "limits": {
            "memory": "1000M"
          }
        }
      }
    }
  ]
}
