{
  "services": [
    {
      "name": "grafana",
      "image": "grafana/grafana-oss:11.3.1",
      "isMain": true,
      "internalPort": 3000,
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/grafana",
          "containerPath": "/var/lib/grafana"
        }
      ]
    }
  ]
}
