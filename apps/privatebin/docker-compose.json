{
  "services": [
    {
      "name": "privatebin",
      "image": "privatebin/nginx-fpm-alpine:1.7.4",
      "isMain": true,
      "internalPort": 8080,
      "dns": [
        "${DNS_IP}"
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/srv/data"
        }
      ]
    }
  ]
}
