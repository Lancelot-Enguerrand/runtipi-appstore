{
  "services": [
    {
      "name": "habittrove",
      "image": "dohsimpson/habittrove",
      "isMain": true,
      "internalPort": 3000,
      "environmnent": {
          "AUTH_SECRET": "HABITTROVE_AUTH_SECRET"
      }
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/app",
          "containerPath": "/app/data"
        }
      ]
    }
  ]
}
